{
  "manifest_version": 3,
  "name": "AI Tagger for Thunderbird",
  "version": "0.1.0",
  "description": "AI-powered email classification and tagging using local Ollama (with future cloud support). Automatically or manually tags emails based on your custom natural language rules.",
  "author": "Your Name",
  "homepage_url": "https://github.com/yourname/thunderbird-ai-tagger",

  "browser_specific_settings": {
    "gecko": {
      "id": "ai-tagger@thunderbird.example.com",
      "strict_min_version": "128.0"
    }
  },

  "permissions": [
    "messagesRead",
    "accountsRead",
    "messagesUpdate",
    "messagesMove",
    "storage",
    "notifications",
    "messagesTags"
  ],

  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],

  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_title": "AI Tagger",
    "default_icon": "icons/icon-32.png"
  }
}
