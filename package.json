{
  "name": "thunderbird-ai-tagger",
  "version": "0.1.20",
  "description": "Thunderbird/Betterbird MailExtension: classify and tag email with a local Ollama LLM using natural-language rules. Private, one-call-per-message, with optional move/archive actions.",
  "main": "background.js",
  "scripts": {
    "lint": "web-ext lint",
    "version:sync": "node scripts/sync-version.js",
    "prebuild": "npm run version:sync",
    "build": "web-ext build --overwrite-dest",
    "run": "web-ext run --target=thunderbird-desktop",
    "start": "web-ext run --target=thunderbird-desktop",
    "package": "npm run build && echo 'Extension packaged in web-ext-artifacts/'"
  },
  "devDependencies": {
    "web-ext": "^8.0.0"
  },
  "webExt": {
    "ignoreFiles": [
      "node_modules/**",
      "web-ext-artifacts/**",
      "package.json",
      "package-lock.json",
      "README.md",
      "CHANGELOG.md",
      "scripts/**",
      ".github/**",
      ".git/**",
      ".gitignore",
      "*.py"
    ]
  },
  "keywords": [
    "thunderbird",
    "betterbird",
    "thunderbird-addon",
    "mail-extension",
    "webextension",
    "mozilla",
    "email",
    "email-classification",
    "email-automation",
    "email-tagger",
    "ai",
    "llm",
    "ollama",
    "local-ai",
    "privacy"
  ],
  "license": "MIT",
  "author": "Mecallie",
  "homepage": "https://github.com/Mecallie/thunderbird-ai-tagger",
  "bugs": {
    "url": "https://github.com/Mecallie/thunderbird-ai-tagger/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Mecallie/thunderbird-ai-tagger.git"
  }
}
